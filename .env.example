# ===== Aplicación =====
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000

# ===== Base de datos =====
# Para desarrollo local con docker-compose
DATABASE_URL=postgresql+asyncpg://sgp:sgp_dev_password@db:5432/sgp_dev
# Para Railway, se inyecta automáticamente

# ===== Autenticación =====
# Por ahora mock. Cuando se integre Clerk:
# CLERK_SECRET_KEY=sk_test_xxx
# CLERK_JWT_VERIFICATION_KEY=...
AUTH_MODE=mock

# ===== CORS =====
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ===== Logging =====
LOG_LEVEL=INFO
LOG_FORMAT=json
